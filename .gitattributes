# Force Unix line endings for all shell scripts — prevents CRLF issues in WSL/Linux
*.sh    text eol=lf
*.bash  text eol=lf
Makefile text eol=lf

# Windows scripts keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Config and text files — Unix endings
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.env*  text eol=lf
.gitignore text eol=lf

# ================================================================
#  AI Agent — Environment Configuration
#  Copy this file to .env and edit the values
#  DO NOT commit .env to git (it's in .gitignore)
# ================================================================

# ----------------------------------------------------------------
#  MODEL SELECTION
#  Pick based on your machine specs (see README for full table)
#
#  Tier 1 — Minimum  (8 GB RAM, CPU only)       : deepseek-r1:7b
#  Tier 2 — Mid      (16 GB RAM or 8 GB VRAM)   : deepseek-r1:14b
#  Tier 3 — Good     (32 GB RAM or 16 GB VRAM)  : deepseek-r1:32b
#  Tier 4 — Server   (64 GB RAM or 24 GB VRAM)  : deepseek-r1:70b
#
#  Cursor Agent / Ask (tool calling): use qwen3 — NOT deepseek-r1
#    make pull-agent   →  qwen3:8b by default
# ----------------------------------------------------------------
OLLAMA_MODEL=deepseek-r1:7b

# Embedding model for document RAG (small, stays in memory cheaply)
RAG_EMBEDDING_MODEL=nomic-embed-text

# ----------------------------------------------------------------
#  OLLAMA STORAGE (where pull-model.sh / ollama pull writes model files)
#
#  Leave unset → Docker named volume "ai-agent-ollama-data" (not a normal D:\ folder).
#
#  WSL2 + D: drive example (files appear under D:\side\ollama-models):
#    OLLAMA_MODELS_DIR=/mnt/d/side/ollama-models
#
#  After changing this: docker compose down, mkdir -p that path, docker compose up -d ollama
# ----------------------------------------------------------------
# OLLAMA_MODELS_DIR=/mnt/d/side/ollama-models

# ----------------------------------------------------------------
#  PORTS  (change only if these conflict with something on your machine)
# ----------------------------------------------------------------
OLLAMA_PORT=11434
WEBUI_PORT=3000
SEARXNG_PORT=8080

# ----------------------------------------------------------------
#  CURSOR IDE — local Ollama (Agent mode / ssrf_blocked workaround)
#
#  Cursor blocks http://localhost in the API override for some flows.
#  Run: make tunnel-cursor   OR   ./scripts/start-cursor-tunnel.sh
#  Then set Override OpenAI Base URL to the printed https URL + /v1
#  Full steps: docs/CURSOR-LOCAL.md
#
#  WSL / firewall: QUIC uses UDP; if cloudflared logs "sendmsg: operation not permitted",
#  keep the default below (http2). Only set quic if UDP works and you want it.
# TUNNEL_TRANSPORT_PROTOCOL=http2
# ----------------------------------------------------------------

# ----------------------------------------------------------------
#  SECURITY
#  Replace with a random 32+ character string
#  Generate one: openssl rand -hex 32
# ----------------------------------------------------------------
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# ----------------------------------------------------------------
#  OPEN WEBUI SETTINGS
#  Set ENABLE_SIGNUP=false after creating your first account
# ----------------------------------------------------------------
ENABLE_SIGNUP=true

# ----------------------------------------------------------------
#  OLLAMA PERFORMANCE TUNING
#
#  OLLAMA_KEEP_ALIVE  : How long model stays hot after last request
#                       0  = unload immediately (saves max RAM)
#                       5m = 5 minutes (balanced default)
#                       -1 = never unload (fastest, uses most RAM)
#
#  OLLAMA_NUM_PARALLEL: Parallel request slots
#                       1 = low-spec machines
#                       2-4 = mid/high-spec machines
#
#  OLLAMA_NUM_THREADS : CPU threads (0 = auto)
#                       Set to physical core count for best performance
# ----------------------------------------------------------------
# Use -1 to keep the last model loaded (helps Cursor+tunnel: first load can exceed ~30s client timeout)
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_THREADS=0

# ----------------------------------------------------------------
#  SEARXNG PERFORMANCE
# ----------------------------------------------------------------
SEARXNG_WORKERS=2
SEARXNG_THREADS=2

# ----------------------------------------------------------------
#  GPU (only needed when using docker-compose.gpu.yml)
# ----------------------------------------------------------------
CUDA_VISIBLE_DEVICES=all
OLLAMA_GPU_LAYERS=999
